# ============================================================
# Agent Admin — Libra Fleet
# ============================================================
# Copiá este archivo a .env y cargá los valores. NO commitear .env.

# ------------------------------------------------------------
# Obligatorias
# ------------------------------------------------------------

# API key de Anthropic (console.anthropic.com → API Keys)
# Formato: sk-ant-...
ANTHROPIC_API_KEY=

# GitHub Personal Access Token con permiso de lectura/escritura al repo
# taller-libra. Fine-grained PAT recomendado, permisos:
#   - Contents: Read and write  (para commits/push desde el agente)
#   - Pull requests: Read and write  (opcional, para PRs)
# Generar en: github.com/settings/tokens?type=beta
# Formato: ghp_... (classic) o github_pat_... (fine-grained)
GITHUB_TOKEN=

# ------------------------------------------------------------
# Se completan automáticamente al correr `npm run setup`
# ------------------------------------------------------------

# ID del Environment cloud creado en Anthropic
ANTHROPIC_ENVIRONMENT_ID=

# ID del Agent persistido (Libra Fleet Dev Agent)
ANTHROPIC_AGENT_ID=
