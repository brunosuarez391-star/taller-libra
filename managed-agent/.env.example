# ============================================
# Libra Fleet — Claude Managed Agent
# ============================================

# Anthropic API key (required)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Personal Access Token (required for repo mounting)
# Create at: https://github.com/settings/tokens
# Scopes needed: Contents (Read and write) for push/PR capability
GITHUB_TOKEN=ghp_...

# GitHub repository URL
GITHUB_REPO_URL=https://github.com/brunosuarez391-star/taller-libra

# Agent and Environment IDs (populated by setup.js)
# After running `npm run setup`, paste the IDs here
AGENT_ID=
AGENT_VERSION=
ENVIRONMENT_ID=
